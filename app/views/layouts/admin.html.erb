<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= [content_for(:title).presence, 'Administration'].compact.join(' — ') %></title>
    <%= csrf_meta_tags %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%= stylesheet_link_tag 'admin' %>
    <%= javascript_importmap_tags 'admin' %>
    <%= yield :head %>
  </head>
  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to 'DDBJ Repository Administration', admin_root_path, class: 'navbar-brand' %>

        <% if current_user %>
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <button type="button" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <%= current_user.uid %>
              </button>

              <ul class="dropdown-menu dropdown-menu-end">
                <li><%= link_to 'Back to repository', '/web/', class: 'dropdown-item', data: {turbo: false} %></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <%= button_to 'Logout', session_path, method: :delete, class: 'dropdown-item', data: {turbo: false} %>
                </li>
              </ul>
            </li>
          </ul>
        <% end %>
      </div>
    </nav>

    <main class="container pb-5">
      <% flash.each do |level, message| %>
        <%# data-controller="flash-focus" scrolls the banner into view on %>
        <%# render so a post-save redirect doesn't leave the notice above %>
        <%# the curator's current scroll position (turbo-refresh-scroll is %>
        <%# preserve so the form-bottom scroll position survives). %>
        <%# The token value re-emits per render so Stimulus fires the %>
        <%# value-change callback even when Turbo morph reuses the .alert %>
        <%# element across saves (connect() would only fire on first mount). %>
        <div class="alert alert-<%= flash_bootstrap_class(level) %> alert-dismissible fade show"
             role="alert"
             data-controller="flash-focus"
             data-flash-focus-token-value="<%= SecureRandom.hex(8) %>">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>

  </body>
</html>
