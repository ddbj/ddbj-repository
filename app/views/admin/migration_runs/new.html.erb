<% content_for :title, 'New migration run' %>

<%= render 'admin/shared/breadcrumb', items: [
  {label: 'Administration',  path: admin_root_path},
  {label: 'Migration runs',  path: admin_migration_runs_path},
  {label: 'New'}
] %>

<h1 class="display-6 mb-4">New migration run</h1>

<p class="text-body-secondary">
  Enqueues a <code>DataMigration::Sync&lt;db&gt;Job</code> against the configured
  D-way staging connection. The job is single-concurrent per database
  (<code>limits_concurrency to: 1</code>); a second enqueue while one is
  running is silently discarded.
</p>

<%= form_with model: @migration_run, url: admin_migration_runs_path, scope: :migration_run do |f| %>
  <div class="mb-3">
    <%= f.label :db, 'Database', class: 'form-label' %>

    <% MigrationRun::DBS.each do |db| %>
      <div class="form-check">
        <%= f.radio_button :db, db, class: 'form-check-input' %>
        <%= f.label "db_#{db}", db_label(db), class: 'form-check-label' %>
      </div>
    <% end %>
  </div>

  <%= f.submit 'Enqueue', class: 'btn btn-primary' %>
  <%= link_to 'Cancel', admin_migration_runs_path, class: 'btn btn-link' %>
<% end %>
