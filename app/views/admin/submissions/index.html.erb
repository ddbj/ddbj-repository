<% content_for :title, 'Submissions' %>

<%= render 'admin/shared/breadcrumb', items: [
  {label: 'Administration', path: admin_root_path},
  {label: 'Submissions'}
] %>

<h1 class="display-6 mb-4">Submissions</h1>

<%= render 'admin/shared/list_filter', url: admin_submissions_path, extra_fields: [
  {name: :source_id, placeholder: 'Source ID (PSUB / SSUB ...)'},
  {name: :accession, placeholder: 'Accession (PRJDB / SAMD ...)'}
] %>

<table class="table border align-middle">
  <thead class="table-light">
    <tr>
      <th>ID</th>
      <th>Database</th>
      <th>User</th>
      <th>Status</th>
      <th>Assignee</th>
      <th>Created</th>
      <th>Updated</th>
    </tr>
  </thead>

  <tbody>
    <% @submissions.each do |submission| %>
      <tr>
        <td><%= link_to submission_label(submission), admin_submission_path(submission) %></td>
        <td><%= db_label(submission.db) %></td>
        <td><%= submission.user.uid %></td>
        <td><%= submission_status_display(submission, @sample_aggregates) %></td>
        <td><%= submission_assignee_display(submission, @sample_aggregates) %></td>
        <td><%= submission.created_at.to_fs(:db) %></td>
        <td><%= submission.updated_at.to_fs(:db) %></td>
      </tr>
    <% end %>

    <% if @submissions.empty? %>
      <tr>
        <td colspan="7" class="text-center text-body-secondary py-4">No submissions found.</td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= render 'admin/shared/pagy_nav', pagy: @pagy %>
