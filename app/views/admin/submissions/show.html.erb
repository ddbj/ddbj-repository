<% content_for :title, submission_label(@submission) %>

<%= render 'admin/shared/breadcrumb', items: [
  {label: 'Administration', path: admin_root_path},
  {label: 'Submissions',    path: admin_submissions_path},
  {label: submission_label(@submission)}
] %>

<h1 class="display-6 mb-4"><%= submission_label(@submission) %></h1>

<dl class="row">
  <dt class="col-sm-3">Database</dt>
  <dd class="col-sm-9"><%= db_label(@submission.db) %></dd>

  <dt class="col-sm-3">Source ID</dt>
  <dd class="col-sm-9"><%= @submission.source_id || '—' %></dd>

  <dt class="col-sm-3">User</dt>
  <dd class="col-sm-9"><%= @submission.user.uid %></dd>

  <dt class="col-sm-3">Canonical version</dt>
  <dd class="col-sm-9">ddbj-canon/v<%= @submission.canonical_version %></dd>

  <dt class="col-sm-3">Converter version</dt>
  <dd class="col-sm-9"><%= @submission.converter_version || '—' %></dd>

  <dt class="col-sm-3">Created / Updated</dt>
  <dd class="col-sm-9"><%= @submission.created_at.to_fs(:db) %> / <%= @submission.updated_at.to_fs(:db) %></dd>

  <% if @canonical_bytes %>
    <dt class="col-sm-3">Canonical bytes</dt>
    <dd class="col-sm-9"><%= number_with_delimiter(@canonical_bytes.bytesize) %> bytes</dd>

    <dt class="col-sm-3">Canonical SHA-256</dt>
    <dd class="col-sm-9"><code><%= @sha256 %></code></dd>
  <% elsif @materialised_size && @materialised_size > Admin::SubmissionsController::CANONICAL_DISPLAY_SIZE_LIMIT %>
    <dt class="col-sm-3">Canonical bytes / SHA-256</dt>
    <dd class="col-sm-9 text-body-secondary">
      Skipped — materialised record is <%= number_to_human_size(@materialised_size) %>
      (limit <%= number_to_human_size(Admin::SubmissionsController::CANONICAL_DISPLAY_SIZE_LIMIT) %>).
      Canonicalisation walks every subtree and costs ~20 s on 7 MB records;
      avoiding it keeps the page interactive.
    </dd>
  <% end %>

  <% if @materialisation_error %>
    <dt class="col-sm-3">Replay status</dt>
    <dd class="col-sm-9 text-danger">
      <%= @materialisation_error.class %>: <%= @materialisation_error.message %>
    </dd>
  <% end %>
</dl>

<% if @submission.bioproject_db? && (project = @submission.project) %>
  <%= render 'admin/projects/curator_edit', submission: @submission, project: project %>
<% end %>

<% if @submission.biosample_db? && @samples_pagy.count.positive? %>
  <h2 class="h4 mt-4">
    Samples
    <span class="badge text-bg-secondary"><%= @samples_pagy.count %></span>
  </h2>

  <%# turbo-frame + data-turbo-action="advance": pagy clicks swap only %>
  <%# this frame (scroll position is preserved) AND push the URL to %>
  <%# browser history so ?samples_page=N is permalinkable / shareable. %>
  <%# frame-scroll-top: after a frame swap, if the user was scrolled past %>
  <%# the top of the table (typical: clicked pagy nav at the bottom of %>
  <%# the previous page), scroll back up so the new page starts at the %>
  <%# table header. Initial page load is left alone. %>
  <turbo-frame id="samples" data-turbo-action="advance" data-controller="frame-scroll-top">
    <table class="table border align-middle">
      <thead class="table-light">
        <tr>
          <th>Accession</th>
          <th>Sample name</th>
          <th>Package</th>
          <th>Organism</th>
          <th>Tax ID</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @samples.each do |sample| %>
          <tr>
            <td><code><%= sample.accession || '—' %></code></td>
            <td><%= sample.sample_name %></td>
            <td><%= sample.package || '—' %></td>
            <td><%= sample.organism || '—' %></td>
            <td><%= sample.taxonomy_id || '—' %></td>
            <td><span class="badge text-bg-light"><%= sample.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= render 'admin/shared/pagy_nav', pagy: @samples_pagy %>
  </turbo-frame>
<% end %>

<h2 class="h4 mt-4">
  Patch chain
  <span class="badge text-bg-secondary"><%= @updates.size %></span>
</h2>

<% if @updates.any? %>
  <table class="table border align-middle">
    <thead class="table-light">
      <tr>
        <th>ID</th>
        <th>Created</th>
        <th>Actor</th>
        <th>Source</th>
        <th class="text-end">Ops</th>
        <th>Patch</th>
        <th>Snapshot</th>
      </tr>
    </thead>
    <tbody>
      <% @updates.each do |update| %>
        <% is_current = update == @updates.last %>
        <% parsed = begin; update.parsed_patch; rescue StandardError => e; e; end %>
        <tr class="<%= 'table-info' if is_current %>">
          <td><code>#<%= update.id %></code></td>
          <td><%= update.created_at.to_fs(:db) %></td>
          <td><%= update.actor || '—' %></td>
          <td><span class="badge text-bg-light"><%= update.source %></span></td>
          <td class="text-end">
            <% if parsed.is_a?(StandardError) %>
              <span class="text-danger" title="unparseable">!</span>
            <% else %>
              <%= parsed.length %>
            <% end %>
          </td>
          <td>
            <details>
              <summary class="small text-body-secondary" role="button">show ops</summary>
              <% if parsed.is_a?(StandardError) %>
                <pre class="mb-0 mt-2 small text-danger bg-body-tertiary border rounded p-2">patch unreadable: <%= parsed.class %>: <%= parsed.message %></pre>
              <% else %>
                <pre class="mb-0 mt-2 small bg-body-tertiary border rounded p-2"><%= JSON.pretty_generate(parsed) %></pre>
              <% end %>
            </details>
          </td>
          <td>
            <%# Snapshot links point to the raw JSON endpoint (the show %>
            <%# page no longer renders snapshots itself; latest is its %>
            <%# only mode). Current row links without ?as_of so the URL %>
            <%# stays clean for the most common click target. %>
            <% if is_current %>
              <%= link_to 'view (JSON)', materialised_admin_submission_path(@submission), class: 'btn btn-sm btn-primary' %>
            <% else %>
              <%= link_to 'view (JSON)', materialised_admin_submission_path(@submission, as_of: update.id), class: 'btn btn-sm btn-outline-secondary' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-body-secondary">No updates have been applied yet — nothing to materialise.</p>
<% end %>

<h2 class="h4 mt-4">Materialised v3 record</h2>

<% if @materialised %>
  <p>
    <%= link_to 'View as JSON', materialised_admin_submission_path(@submission), class: 'btn btn-primary' %>
    <%# Labelled "JSON:" to distinguish from "Canonical bytes" above — %>
    <%# they're structurally different sizes (canonical strips volatile %>
    <%# fields + sorts keys + normalises). %>
    <span class="text-body-secondary ms-2">
      JSON: <%= number_to_human_size(@materialised_size) %>
    </span>
  </p>
<% elsif @materialisation_error %>
  <div class="alert alert-danger" role="alert">
    Replay failed. See the Replay status field above; the patch chain table
    is rendered as-is so the bad row (<code>#<%= @materialisation_error.try(:update_id) || '?' %></code>) can be located.
  </div>
<% else %>
  <p class="text-body-secondary">No updates have been applied yet — nothing to materialise.</p>
<% end %>
