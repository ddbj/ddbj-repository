<% content_for :title, 'Administration' %>

<%= render 'admin/shared/breadcrumb', items: [{label: 'Administration'}] %>

<h1 class="display-6 mb-4">Administration</h1>

<h2 class="h5 mt-4">Browse</h2>

<div class="row g-3">
  <div class="col-md-4">
    <%= link_to admin_submission_requests_path, class: 'card text-decoration-none h-100' do %>
      <div class="card-body">
        <h3 class="card-title h5">Submission requests</h3>
        <p class="card-text text-body-secondary mb-0">Browse submission requests across all DBs and users.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <%= link_to admin_submissions_path, class: 'card text-decoration-none h-100' do %>
      <div class="card-body">
        <h3 class="card-title h5">Submissions</h3>
        <p class="card-text text-body-secondary mb-0">Browse applied submissions across all DBs and users.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <%= link_to admin_users_path, class: 'card text-decoration-none h-100' do %>
      <div class="card-body">
        <h3 class="card-title h5">Users</h3>
        <p class="card-text text-body-secondary mb-0">Browse DDBJ accounts and proxy-login as one of them.</p>
      </div>
    <% end %>
  </div>
</div>

<h2 class="h5 mt-5">Tools</h2>

<div class="row g-3">
  <div class="col-md-4">
    <%= link_to admin_regenerate_flatfiles_path, class: 'card text-decoration-none h-100' do %>
      <div class="card-body">
        <h3 class="card-title h5">Regenerate Flatfiles</h3>
        <p class="card-text text-body-secondary mb-0">Recreate flatfiles for all submissions.</p>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <%= link_to admin_mission_control_jobs_path, class: 'card text-decoration-none h-100' do %>
      <div class="card-body">
        <h3 class="card-title h5">Jobs</h3>
        <p class="card-text text-body-secondary mb-0">Inspect background job queues and failures.</p>
      </div>
    <% end %>
  </div>
</div>
