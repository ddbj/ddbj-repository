<%# Curator-edit form for v3 `submission.comments: list[str]`. %>
<%# Each non-blank line in the textarea becomes one entry; saving %>
<%# appends a SubmissionUpdate to the patch chain. %>
<section class="card mt-4">
  <div class="card-body">
    <h2 class="h5 card-title">Comments</h2>

    <p class="text-body-secondary small">
      Free-form curator notes on this submission. Each non-blank line becomes one entry in
      <code>submission.comments[]</code>. Saving generates a new patch in the update chain.
    </p>

    <% current_comments = (submission.materialised_record.dig('submission', 'comments') || []).join("\n") %>

    <%= form_with url: admin_submission_comments_path(submission),
                  method: :patch,
                  scope:  :submission_comments,
                  local:  true do |f| %>
      <div class="mb-3">
        <%= f.label :body, 'Comments (one per line)', class: 'form-label' %>
        <%= f.text_area :body, value: current_comments, rows: 4, class: 'form-control font-monospace small' %>
      </div>

      <%= f.submit 'Save comments', class: 'btn btn-primary' %>
    <% end %>
  </div>
</section>
