<% content_for :title, "Edit sample ##{@sample.id}" %>

<%= render 'admin/shared/breadcrumb', items: [
  {label: 'Administration', path: admin_root_path},
  {label: 'Submissions',    path: admin_submissions_path},
  {label: submission_label(@sample.submission), path: admin_submission_path(@sample.submission)},
  {label: "Sample ##{@sample.id}"}
] %>

<h1 class="display-6 mb-4">Edit sample</h1>

<dl class="row">
  <dt class="col-sm-3">Accession</dt>
  <dd class="col-sm-9"><code><%= @sample.accession || '—' %></code></dd>

  <dt class="col-sm-3">Sample name</dt>
  <dd class="col-sm-9"><%= @sample.sample_name %></dd>

  <dt class="col-sm-3">Package</dt>
  <dd class="col-sm-9"><%= @sample.package || '—' %></dd>

  <dt class="col-sm-3">Organism</dt>
  <dd class="col-sm-9"><%= @sample.organism || '—' %></dd>
</dl>

<%= form_with model: @sample, url: admin_sample_path(@sample), method: :patch, local: true do |f| %>
  <div class="row g-3 mb-3">
    <div class="col-md-5">
      <%= f.label :status, class: 'form-label' %>
      <%= f.select :status,
                   Sample.statuses.keys.map {|s| [s.tr('_', ' ').capitalize, s] },
                   {include_blank: '— Leave as-is —'},
                   class: 'form-select' %>
    </div>

    <div class="col-md-5">
      <%= f.label :assignee_id, 'Assignee', class: 'form-label' %>
      <%= f.select :assignee_id,
                   [['— Unassigned —', '0']] + User.staff.order(:uid).pluck(:uid, :id),
                   {include_blank: '— Leave as-is —', selected: @sample.assignee_id&.to_s},
                   class: 'form-select' %>
    </div>
  </div>

  <%= f.submit 'Save sample', class: 'btn btn-primary' %>
  <%= link_to 'Cancel', admin_submission_path(@sample.submission), class: 'btn btn-link' %>
<% end %>
