# locals: (submission_request:, unread_submission_ids: Set.new)

submission = submission_request.submission

{
  **submission_request.slice(:id, :db, :status, :created_at),

  submission_id:              submission&.id,
  has_accession:              submission&.accessions&.any? || false,
  has_unread_curator_message: submission ? unread_submission_ids.include?(submission.id) : false
}
