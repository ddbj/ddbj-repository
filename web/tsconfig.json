{
  "extends": "@tsconfig/ember",
  "compilerOptions": {
    // `paths` allows Ember's classic package layout, which is not resolvable
    // with the Node resolution algorithm, to work with TypeScript.
    "paths": {
      "repository/tests/*": ["./tests/*"],
      "repository/*": ["./app/*"],
      "schema/*": ["../schema/*"],
      "*": ["./types/*"]
    },
    "types": ["ember-source/types", "@embroider/core/virtual", "vite/client"]
  },
  "include": ["app", "tests", "types", "node_modules/@ember-data/request/unstable-preview-types"]
}
